*.dat
*.bed
*.txt

# --- Python bytecode ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Build artifacts (PyInstaller — likely packaging method for .exe) ---
build/
dist/
*.spec
*.manifest
*.exe

# --- Python packaging ---
*.egg-info/
*.egg
MANIFEST
.installed.cfg

# --- Environment variables and local settings ---
.env
.envrc

# --- IDE settings ---
.idea/
.vscode/
.spyderproject
.ropeproject

# --- Tool caches ---
.mypy_cache/
.ruff_cache/
.pytest_cache/
.hypothesis/

# --- Tests and coverage ---
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# --- macOS / Windows junk ---
.DS_Store
Thumbs.db
desktop.ini
